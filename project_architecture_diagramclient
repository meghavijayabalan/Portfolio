    classDef mongo fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px;
    classDef jobs fill:#eceff1,stroke:#37474f,stroke-width:2px;
    classDef pg fill:#e1f5fe,stroke:#0277bd,stroke-width:2px;
    classDef cache fill:#fffde7,stroke:#fbc02d,stroke-width:2px;

    %% Source Mongo
    subgraph Mongo [MongoDB Source DB]
        CP[(chargepoints)]:::mongo
        LOC[(locations)]:::mongo
        EVS[(evses)]:::mongo
        CUST[(customers)]:::mongo
        ORG[(organisations)]:::mongo
    end

    %% Sync Jobs
    subgraph Scheduler [APScheduler Sync Jobs]
        ACDC[maintenance_job_acdc<br/>Detect Uptime/Outages]:::jobs
        DAG[maintenanceDailyAgg<br/>Daily aggregates]:::jobs
        HAG[maintenanceHourlyAgg<br/>Hourly state logs]:::jobs
        ETL[transaction ETL<br/>Daily sessions sync]:::jobs
        EN[hourly_monthly_energy<br/>Compile Energy/Solar Splits]:::jobs
        CHG[charger_db_sync<br/>Cache Builder]:::jobs
    end

    %% PostgreSQL Tables
    subgraph Postgres [PostgreSQL Target Tables]
        TLIVE[(maintenance_live)]:::pg
        THIST[(maintenance_history)]:::pg
        TDAG[(maintenance_daily_agg)]:::pg
        THAG[(maintenance_hourly_agg)]:::pg
        TTX[(transactions)]:::pg
        TEH[(ev_hourly_metrics)]:::pg
        TEM[(ev_monthly_metrics)]:::pg
    end

    %% Cache
    CACHE[all_chargers_db.json]:::cache

    %% Pipelines
    CP --> ACDC
    EVS --> ACDC
    ACDC --> TLIVE
    ACDC --> THIST
    
    TLIVE --> DAG --> TDAG
    THIST --> DAG
    TLIVE --> HAG --> THAG
    
    CP --> ETL --> TTX
    CP --> EN --> TEH
    EN --> TEM
    
    CP --> CHG --> CACHE
    LOC --> CHG
```

