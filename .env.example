# Flask configuration
SECRET_KEY=replace-this-with-a-very-secure-random-key

# SMTP configuration for contact form
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password

# Recipient email for form submission (falls back to email in profile_data if not set)
CONTACT_TO=megharajvs@example.com

# Formspree configuration (alternative to SMTP)
# If FORMSPREE_FORM_ID is set, the app will use Formspree instead of SMTP.
FORMSPREE_FORM_ID=
